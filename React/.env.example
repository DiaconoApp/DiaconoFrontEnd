# ===========================================
# Arquivo de exemplo de variáveis de ambiente
# Copie este arquivo para .env e configure os valores
# ===========================================

# Configurações da API Backend
# IP do servidor da API (ex: localhost, 192.168.1.100, api.exemplo.com)
VITE_API_IP=localhost

# Porta do servidor da API (ex: 8080, 3000)
VITE_API_PORT=8080

# Google OAuth Client ID
# Exemplo: 1234567890-abc123def456.apps.googleusercontent.com
VITE_GOOGLE_CLIENT_ID=
